				<Item class="ModuleScript" referent="11">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[--!strict

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local ChampionData = require(ReplicatedStorage.Modules.ChampionData)
local SharedConstants = require(ReplicatedStorage.Modules.SharedConstants)
local Utility = require(script.Parent.Utility)
local EconomyProgressionService = require(script.Parent.EconomyProgressionService)
local ChampionService = {}

local function getSpawnForTeam(teamName: string): BasePart?
	local map = Workspace:FindFirstChild("Map")
	if not map then
		warn("[MOBA] Workspace.Map manquant : impossible de placer les champions.")
		return nil
	end
	local playerSpawns = map:FindFirstChild("PlayerSpawns")
	if not playerSpawns then
		warn("[MOBA] Workspace.Map.PlayerSpawns manquant.")
		return nil
	end
	local spawn = playerSpawns:FindFirstChild(teamName)
	if spawn and spawn:IsA("BasePart") then
		return spawn
	end
	warn("[MOBA] Spawn joueur manquant pour l'équipe", teamName)
	return nil
end

local function setupCharacter(player: Player, character: Model)
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		humanoid = character:WaitForChild("Humanoid", 10) :: Humanoid?
	end
	local root = character:FindFirstChild("HumanoidRootPart")
	if not root then
		root = character:WaitForChild("HumanoidRootPart", 10)
	end
	if not humanoid or not humanoid:IsA("Humanoid") or not root or not root:IsA("BasePart") then
		warn("[MOBA] Champion incomplet pour", player.Name)
		return
	end

	local selectedChampionId = player:GetAttribute("SelectedChampionId")
	local data = ChampionData.getChampion(if typeof(selectedChampionId) == "string" then selectedChampionId else nil)
	if selectedChampionId ~= data.Id then
		player:SetAttribute("SelectedChampionId", data.Id)
	end

	local teamName = player:GetAttribute("Team")
	if typeof(teamName) ~= "string" then
		teamName = SharedConstants.TEAMS.BLUE
		player:SetAttribute("Team", teamName)
	end

	character:SetAttribute("UnitType", "Champion")
	character:SetAttribute("OwnerUserId", player.UserId)
	character:SetAttribute("Team", teamName)
	character:SetAttribute("ChampionId", data.Id)
	character:SetAttribute("ChampionRole", data.Role)
	character:SetAttribute("MaxHealth", data.MaxHealth)
	character:SetAttribute("Health", data.MaxHealth)
	character:SetAttribute("AttackDamage", data.AttackDamage)
	character:SetAttribute("AttackRange", data.AttackRange)
	character:SetAttribute("AttackCooldown", data.AttackCooldown)
	character:SetAttribute("MoveSpeed", data.MoveSpeed)
	character:SetAttribute("InventoryCount", 0)
	character:SetAttribute("Dead", false)

	EconomyProgressionService.applyPlayerProgressionToChampion(player, character)

	local restoredMaxHealth = character:GetAttribute("MaxHealth")
	if typeof(restoredMaxHealth) == "number" then
		character:SetAttribute("Health", restoredMaxHealth)
	end

	local finalMaxHealth = character:GetAttribute("MaxHealth")
	if typeof(finalMaxHealth) ~= "number" then
		finalMaxHealth = data.MaxHealth
	end
	local finalMoveSpeed = character:GetAttribute("MoveSpeed")
	if typeof(finalMoveSpeed) ~= "number" then
		finalMoveSpeed = data.MoveSpeed
	end

	humanoid.WalkSpeed = finalMoveSpeed

	humanoid.MaxHealth = finalMaxHealth
	humanoid.Health = finalMaxHealth

	local units = Workspace:FindFirstChild("Units")
	if not units or not units:IsA("Folder") then
		warn("[MOBA] Workspace.Units manquant : champion non enregistré.")
		return
	end
	character.Parent = units
	local spawn = getSpawnForTeam(teamName)
	if spawn then
		character:PivotTo(spawn.CFrame + Vector3.new(0, 4, 0))
	end
	Utility.attachHealthBar(character)
	print(string.format("[MOBA] %s spawned as %s", player.Name, data.DisplayName))

	local watchedAttributes = {
		"ChampionId",
		"ChampionRole",
		"Level",
		"Gold",
		"XP",
		"MaxHealth",
		"AttackDamage",
		"AttackRange",
		"AttackCooldown",
		"MoveSpeed",
		"InventoryCount",
		"InventorySlot1",
		"InventorySlot2",
		"InventorySlot3",
		"InventorySlot4",
		"InventorySlot5",
		"InventorySlot6",
	}

	for _, attributeName in watchedAttributes do
		character:GetAttributeChangedSignal(attributeName):Connect(function()
			print(string.format(
				"[MOBA][STATS] %s %s = %s",
				player.Name,
				attributeName,
				tostring(character:GetAttribute(attributeName))
			))
		end)
	end
end

local function ensurePlayerStats(player: Player)
	if typeof(player:GetAttribute("Kills")) ~= "number" then
		player:SetAttribute("Kills", 0)
	end
	if typeof(player:GetAttribute("Deaths")) ~= "number" then
		player:SetAttribute("Deaths", 0)
	end
	if typeof(player:GetAttribute("Assists")) ~= "number" then
		player:SetAttribute("Assists", 0)
	end
	if typeof(player:GetAttribute("CS")) ~= "number" then
		player:SetAttribute("CS", 0)
	end
end

local function initializePlayer(player: Player)
	ensurePlayerStats(player)
	player.CharacterAdded:Connect(function(character)
		task.defer(setupCharacter, player, character)
	end)
	if player.Character then
		task.defer(setupCharacter, player, player.Character)
	end
end

function ChampionService.getChampionFromPlayer(player: Player): Model?
	local character = player.Character
	if character and character.Parent and character:GetAttribute("UnitType") == "Champion" then
		return character
	end
	local units = Workspace:FindFirstChild("Units")
	if units then
		for _, unit in units:GetChildren() do
			if unit:IsA("Model") and unit:GetAttribute("UnitType") == "Champion" and unit:GetAttribute("OwnerUserId") == player.UserId then
				return unit
			end
		end
	end
	return nil
end

function ChampionService.setSelectedChampion(player: Player, championId: string): (boolean, string)
	local targetData = ChampionData.Champions[championId]
	if not targetData then
		return false, "Unknown champion"
	end

	local champion = ChampionService.getChampionFromPlayer(player)
	local shouldRespawn = champion ~= nil and champion:GetAttribute("Dead") ~= true
	if champion and shouldRespawn then
		EconomyProgressionService.saveChampionProgressionToPlayer(champion)

		local currentChampionId = champion:GetAttribute("ChampionId")
		local currentData = ChampionData.getChampion(
			if typeof(currentChampionId) == "string" then currentChampionId else nil
		)
		local currentMaxHealth = champion:GetAttribute("MaxHealth")
		local currentAttackDamage = champion:GetAttribute("AttackDamage")
		local maxHealthBonus = if typeof(currentMaxHealth) == "number"
			then currentMaxHealth - currentData.MaxHealth
			else 0
		local attackDamageBonus = if typeof(currentAttackDamage) == "number"
			then currentAttackDamage - currentData.AttackDamage
			else 0

		player:SetAttribute("ProgressionMaxHealth", math.max(1, targetData.MaxHealth + maxHealthBonus))
		player:SetAttribute("ProgressionAttackDamage", targetData.AttackDamage + attackDamageBonus)
	end

	player:SetAttribute("SelectedChampionId", championId)
	print(string.format("[MOBA] %s selected champion %s", player.Name, targetData.DisplayName))

	if shouldRespawn then
		player:LoadCharacter()
	end

	return true, "Selected"
end

function ChampionService.start()
	for _, player in Players:GetPlayers() do
		initializePlayer(player)
	end
	Players.PlayerAdded:Connect(initializePlayer)
end

return ChampionService
]]></ProtectedString>
						<string name="ScriptGuid">{2f90ab6f-1b8a-4da0-90e5-66b581b6ebb0}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">ChampionService</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">458c3168aa8c2cf20a4d7f0f000003bc</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="12">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[--!strict
local EconomyProgressionService = require(script.Parent.EconomyProgressionService)
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")

local SharedConstants = require(ReplicatedStorage.Modules.SharedConstants)
local Utility = require(script.Parent.Utility)
local VisionService = require(script.Parent.VisionService)

local CombatService = {}
local lastAttackByUnit = setmetatable({}, { __mode = "k" })

type DamageListener = (Instance, Instance, number) -> ()
local damageListeners: { DamageListener } = {}

function CombatService.onDamage(listener: DamageListener)
	table.insert(damageListeners, listener)
end

local function emitDamage(attacker: Instance, target: Instance, damage: number)
	for _, listener in damageListeners do
		task.spawn(listener, attacker, target, damage)
	end
end

local championAggroEvent = ServerStorage:FindFirstChild("MobaChampionAggro")
if not championAggroEvent or not championAggroEvent:IsA("BindableEvent") then
	if championAggroEvent then
		championAggroEvent:Destroy()
	end
	championAggroEvent = Instance.new("BindableEvent")
	championAggroEvent.Name = "MobaChampionAggro"
	championAggroEvent.Parent = ServerStorage
end

local VALID_ATTACKERS = {
	Champion = true,
	Minion = true,
	Tower = true,
	JungleMonster = true,
}

local VALID_TARGETS = {
	Champion = true,
	Minion = true,
	Tower = true,
	JungleMonster = true,
	Nexus = true,
	Inhibitor = true,
}

local function emitCombatFeedback(attacker: Instance, target: Instance, damage: number)
	local remotes = ReplicatedStorage:FindFirstChild("Remotes")
	local remote = remotes and remotes:FindFirstChild(SharedConstants.REMOTES.COMBAT_FEEDBACK)
	if remote and remote:IsA("RemoteEvent") then
		remote:FireAllClients(attacker, target, damage)
	end
end

local function getNumberAttribute(unit: Instance, name: string, fallback: number): number
	local value = unit:GetAttribute(name)
	return if typeof(value) == "number" then value else fallback
end

local function getUnitType(unit: Instance): string?
	local unitType = unit:GetAttribute("UnitType")
	return if typeof(unitType) == "string" then unitType else nil
end

local function getGameSpeed(): number
	local debugConfig = SharedConstants.DEBUG
	if typeof(debugConfig) ~= "table" then
		return 1
	end

	local speed = debugConfig.GAME_SPEED
	if typeof(speed) ~= "number" or speed <= 0 then
		return 1
	end

	return speed
end

local function getPlayerFromChampion(champion: Instance): Player?
	if not champion or not champion:IsA("Model") then
		return nil
	end

	local ownerUserId = champion:GetAttribute("OwnerUserId")
	if typeof(ownerUserId) ~= "number" then
		return nil
	end

	for _, player in ipairs(Players:GetPlayers()) do
		if player.UserId == ownerUserId then
			return player
		end
	end

	return nil
end

local function canAttack(attacker: Instance, target: Instance, player: Player?): (boolean, string)
	local attackerType = getUnitType(attacker)
	local targetType = getUnitType(target)
	if not attackerType or not VALID_ATTACKERS[attackerType] then
		return false, "Invalid attacker type"
	end
	if not targetType or not VALID_TARGETS[targetType] then
		return false, "Invalid target type"
	end
	if player and attackerType ~= "Champion" then
		return false, "Player can only command champion attacks"
	end
	if player then
		local ownerUserId = attacker:GetAttribute("OwnerUserId")
		if typeof(ownerUserId) ~= "number" or ownerUserId ~= player.UserId then
			return false, "Player does not own attacker"
		end
	end
	if not Utility.isAlive(attacker) then
		return false, "Attacker dead"
	end
	if not Utility.isAlive(target) then
		return false, "Target dead"
	end
	if not Utility.areEnemies(attacker, target) then
		return false, "Not enemies"
	end

	local range = getNumberAttribute(attacker, "AttackRange", SharedConstants.COMBAT.AUTO_ATTACK_RANGE)
	if Utility.distance(attacker, target) > range then
		return false, "Out of range"
	end

	local now = os.clock()
	local lastAttack = lastAttackByUnit[attacker] or 0
	local cooldown = getNumberAttribute(attacker, "AttackCooldown", SharedConstants.COMBAT.AUTO_ATTACK_COOLDOWN)
	if now - lastAttack < cooldown / getGameSpeed() then
		return false, "Attack cooldown"
	end

	if player and not VisionService.canPlayerSeeUnit(player, target) then
		return false, "Target not visible"
	end

	return true, "OK"
end

function CombatService.applyDamage(attacker: Instance, target: Instance, amount: number)
	local health = target:GetAttribute("Health")
	if typeof(health) ~= "number" then
		return
	end
	local damage = math.min(math.max(amount, 0), health)
	Utility.setHealth(target, health - damage)

	if damage > 0 then
		emitCombatFeedback(attacker, target, damage)
		emitDamage(attacker, target, damage)
	end
	if target:GetAttribute("Dead") == true then
		CombatService.handleDeath(attacker, target)
	end
end

function CombatService.handleDeath(killer: Instance, victim: Instance)
	local victimIsChampion = victim:GetAttribute("UnitType") == "Champion"
	local victimNoRewards = victim:GetAttribute("NoRewards") == true
	local victimTrainingDummy = victim:GetAttribute("IsTrainingDummy") == true

	if victimIsChampion and not victimNoRewards and not victimTrainingDummy then
		local victimPlayer = getPlayerFromChampion(victim)
		if victimPlayer then
			local deaths = getNumberAttribute(victimPlayer, "Deaths", 0)
			victimPlayer:SetAttribute("Deaths", deaths + 1)
		end
	end

	if killer and killer:GetAttribute("UnitType") == "Champion" and victimIsChampion then
		local killerTrainingDummy = killer:GetAttribute("IsTrainingDummy") == true
		local killerNoRewards = killer:GetAttribute("NoRewards") == true
		if not killerTrainingDummy and not killerNoRewards and not victimNoRewards and not victimTrainingDummy then
			local killerPlayer = getPlayerFromChampion(killer)
			local victimPlayer = getPlayerFromChampion(victim)
			if killerPlayer and killerPlayer ~= victimPlayer then
				local kills = getNumberAttribute(killerPlayer, "Kills", 0)
				killerPlayer:SetAttribute("Kills", kills + 1)
			end
		end
	end

	EconomyProgressionService.awardKillRewards(killer, victim)

	if victimIsChampion then
		EconomyProgressionService.saveChampionProgressionToPlayer(victim)
	end

	victim:SetAttribute("Dead", true)
	local root = Utility.getRoot(victim)
	if root then
		root.CanCollide = false
	end
	local humanoid = victim:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid.Health = 0
	end
end

function CombatService.tryAutoAttack(attacker: Instance, target: Instance, player: Player?): (boolean, string)
	local allowed, reason = canAttack(attacker, target, player)
	if not allowed then
		return false, reason
	end

	lastAttackByUnit[attacker] = os.clock()
	local damage = getNumberAttribute(attacker, "AttackDamage", SharedConstants.COMBAT.BASE_ATTACK_DAMAGE)
	CombatService.applyDamage(attacker, target, damage)
	if getUnitType(attacker) == "Champion" and getUnitType(target) == "Champion" then
		(championAggroEvent :: BindableEvent):Fire(attacker, target)
	end
	return true, "Attack success"
end

return CombatService
]]></ProtectedString>
