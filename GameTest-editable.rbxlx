						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[--!strict

local Workspace = game:GetService("Workspace")

local CombatService = require(script.Parent.CombatService)
local Utility = require(script.Parent.Utility)

local TowerService = {}

local function findTarget(tower: Model): Instance?
	local units = Workspace:FindFirstChild("Units")
	if not units then
		return nil
	end

	local bestMinion = nil
	local bestChampion = nil
	local bestObjective = nil
	local bestMinionDistance = math.huge
	local bestChampionDistance = math.huge
	local bestObjectiveDistance = math.huge
	local rangeAttribute = tower:GetAttribute("AttackRange")
	local range = if typeof(rangeAttribute) == "number" then rangeAttribute else 90

	for _, candidate in units:GetChildren() do
		if Utility.isAlive(candidate) and Utility.areEnemies(tower, candidate) then
			local distance = Utility.distance(tower, candidate)
			if distance <= range then
				local unitType = candidate:GetAttribute("UnitType")
				if unitType == "Minion" and distance < bestMinionDistance then
					bestMinion = candidate
					bestMinionDistance = distance
				elseif unitType == "Champion" and distance < bestChampionDistance then
					bestChampion = candidate
					bestChampionDistance = distance
				elseif unitType == "Nexus" and distance < bestObjectiveDistance then
					bestObjective = candidate
					bestObjectiveDistance = distance
				end
			end
		end
	end
	return bestMinion or bestChampion or bestObjective
end

local function runTower(tower: Model)
	Utility.attachHealthBar(tower)
	task.spawn(function()
		while tower.Parent and Utility.isAlive(tower) do
			local target = findTarget(tower)
			if target then
				CombatService.tryAutoAttack(tower, target, nil)
			end
			task.wait(0.2)
		end
	end)
end

function TowerService.start()
	local map = Workspace:FindFirstChild("Map")
	if not map then
		warn("[MOBA] Workspace.Map manquant : tours non démarrées.")
		return
	end
	local towers = map:FindFirstChild("Towers")
	if not towers then
		warn("[MOBA] Workspace.Map.Towers manquant.")
		return
	end
	local units = Workspace:FindFirstChild("Units")
	if not units or not units:IsA("Folder") then
		warn("[MOBA] Workspace.Units manquant : tours non enregistrées.")
		return
	end
	for _, tower in towers:GetChildren() do
		if tower:IsA("Model") then
			tower.Parent = units
			runTower(tower)
		end
	end
end

return TowerService
]]></ProtectedString>
