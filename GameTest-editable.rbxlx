				</Item>
				<Item class="ModuleScript" referent="20">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[--!strict

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local JungleData = require(ReplicatedStorage.Modules.JungleData)
local MinionData = require(ReplicatedStorage.Modules.MinionData)
local Utility = require(script.Parent.Utility)

local UnitFactory = {}

local TEAM_COLORS = {
	Blue = Color3.fromRGB(55, 151, 255),
	Red = Color3.fromRGB(239, 71, 78),
	Neutral = Color3.fromRGB(190, 142, 75),
}

local function createVisualUnit(name: string, position: Vector3, color: Color3, scale: number): Model
	local model = Instance.new("Model")
	model.Name = name

	local root = Instance.new("Part")
	root.Name = "HumanoidRootPart"
	root.Anchored = true
	root.CanCollide = false
	root.CanTouch = false
	root.Size = Vector3.new(scale, scale, scale)
	root.CFrame = CFrame.new(position + Vector3.new(0, scale / 2, 0))
	root.Color = color
	root.Material = Enum.Material.SmoothPlastic
	root.Shape = Enum.PartType.Ball
	root.Parent = model

	local accent = Instance.new("Part")
	accent.Name = "Accent"
	accent.Anchored = true
	accent.CanCollide = false
	accent.CanTouch = false
	accent.Size = Vector3.new(scale * 0.62, scale * 0.62, scale * 0.62)
	accent.CFrame = root.CFrame * CFrame.new(0, scale * 0.62, 0)
	accent.Color = color:Lerp(Color3.new(1, 1, 1), 0.35)
	accent.Material = Enum.Material.Neon
	accent.Shape = Enum.PartType.Ball
	accent.Parent = model

	model.PrimaryPart = root
	return model
end

function UnitFactory.createMinion(teamName: string, minionType: string, position: Vector3): Model?
	if not minionType then
		warn("[MOBA] Minion has no minion type")
		return nil
	end

	local data = MinionData and MinionData.Types and MinionData.Types[minionType]
	if not data then
		warn("[MOBA] Invalid or missing minion data for minion type:", minionType)
		return nil
	end

	local color = TEAM_COLORS[teamName] or Color3.new(1, 1, 1)
	local minion = createVisualUnit(teamName .. minionType, position, color, data.Scale)
	minion:SetAttribute("UnitType", "Minion")
	minion:SetAttribute("Team", teamName)
	minion:SetAttribute("MinionType", minionType)
	minion:SetAttribute("MaxHealth", data.MaxHealth)
	minion:SetAttribute("Health", data.MaxHealth)
	minion:SetAttribute("AttackDamage", data.AttackDamage)
	minion:SetAttribute("AttackRange", data.AttackRange)
	minion:SetAttribute("AttackCooldown", data.AttackCooldown)
	minion:SetAttribute("MoveSpeed", data.MoveSpeed)
	minion:SetAttribute("GoldReward", data.GoldReward)
	minion:SetAttribute("XPReward", data.XPReward)
	minion:SetAttribute("Dead", false)
	Utility.attachHealthBar(minion)
	return minion
end

function UnitFactory.createJungleMonster(campType: string, position: Vector3): Model?
	if not campType then
		warn("[MOBA] Jungle camp has no CampType attribute")
		return nil
	end

	local data = JungleData and JungleData.Camps and JungleData.Camps[campType]
	if not data then
		warn("[MOBA] Invalid or missing jungle camp data for camp type:", campType)
		return nil
	end

	local monster = createVisualUnit(campType, position, TEAM_COLORS.Neutral, data.Scale)
	monster:SetAttribute("UnitType", "JungleMonster")
	monster:SetAttribute("Team", "Neutral")
	monster:SetAttribute("CampType", campType)
	monster:SetAttribute("MaxHealth", data.MaxHealth)
	monster:SetAttribute("Health", data.MaxHealth)
	monster:SetAttribute("AttackDamage", data.AttackDamage)
	monster:SetAttribute("AttackRange", data.AttackRange)
	monster:SetAttribute("AttackCooldown", data.AttackCooldown)
	monster:SetAttribute("GoldReward", data.GoldReward)
	monster:SetAttribute("XPReward", data.XPReward)
	monster:SetAttribute("Dead", false)
	Utility.attachHealthBar(monster)
	return monster
end

return UnitFactory
]]></ProtectedString>
						<string name="ScriptGuid">{14a43fcc-ce22-406a-b853-483a35f1936b}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">UnitFactory</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">458c3168aa8c2cf20a4d7f0f000003c5</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="21">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[--!strict

local Utility = {}

function Utility.getRoot(unit: Instance?): BasePart?
	if not unit then
		return nil
	end

	if unit:IsA("BasePart") then
		return unit
	end

	if unit:IsA("Model") then
		local humanoidRootPart = unit:FindFirstChild("HumanoidRootPart")
		if humanoidRootPart and humanoidRootPart:IsA("BasePart") then
			return humanoidRootPart
		end
		return unit.PrimaryPart
	end

	return nil
end

function Utility.distance(a: Instance?, b: Instance?): number
	local rootA = Utility.getRoot(a)
	local rootB = Utility.getRoot(b)
	if not rootA or not rootB then
		return math.huge
	end
	return (rootA.Position - rootB.Position).Magnitude
end

function Utility.isAlive(unit: Instance?): boolean
	if not unit or not unit.Parent then
		return false
	end
	if unit:GetAttribute("Dead") == true then
		return false
	end

	local health = unit:GetAttribute("Health")
	if typeof(health) == "number" then
		return health > 0
	end

	local humanoid = unit:FindFirstChildOfClass("Humanoid")
	if humanoid then
		return humanoid.Health > 0
	end

	return false
end

function Utility.getTeam(unit: Instance?): string?
	if not unit then
		return nil
	end
	local teamName = unit:GetAttribute("Team")
	return if typeof(teamName) == "string" then teamName else nil
end

function Utility.areEnemies(a: Instance?, b: Instance?): boolean
	local teamA = Utility.getTeam(a)
	local teamB = Utility.getTeam(b)
	if not teamA or not teamB then
		return false
	end
	if teamA == "Neutral" and teamB == "Neutral" then
		return false
	end
	return teamA ~= teamB
end

function Utility.setHealth(unit: Instance, value: number)
	local maxHealthAttribute = unit:GetAttribute("MaxHealth")
	local maxHealth = if typeof(maxHealthAttribute) == "number" then maxHealthAttribute else value
	local newHealth = math.clamp(value, 0, maxHealth)
	unit:SetAttribute("Health", newHealth)

	local humanoid = unit:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid.MaxHealth = maxHealth
		humanoid.Health = newHealth
	end

	if newHealth <= 0 then
		unit:SetAttribute("Dead", true)
	end
end

function Utility.attachHealthBar(unit: Instance)
	local root = Utility.getRoot(unit)
	if not root then
		warn("[MOBA] Impossible d'ajouter une barre de vie, root manquant pour", unit:GetFullName())
		return
	end
	if root:FindFirstChild("MobaHealthBar") then
		return
	end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "MobaHealthBar"
	billboard.AlwaysOnTop = true
	billboard.Size = UDim2.fromOffset(80, 10)
	billboard.StudsOffsetWorldSpace = Vector3.new(0, math.max(root.Size.Y * 0.75, 3), 0)
	billboard.Parent = root

	local background = Instance.new("Frame")
	background.Name = "Background"
	background.Size = UDim2.fromScale(1, 1)
	background.BackgroundColor3 = Color3.fromRGB(50, 15, 18)
	background.BorderSizePixel = 0
	background.Parent = billboard

	local fill = Instance.new("Frame")
	fill.Name = "Fill"
	fill.Size = UDim2.fromScale(1, 1)
	fill.BackgroundColor3 = Color3.fromRGB(55, 205, 105)
	fill.BorderSizePixel = 0
	fill.Parent = background

	local function update()
		local health = unit:GetAttribute("Health")
		local maxHealth = unit:GetAttribute("MaxHealth")
		if typeof(health) == "number" and typeof(maxHealth) == "number" and maxHealth > 0 then
			fill.Size = UDim2.fromScale(math.clamp(health / maxHealth, 0, 1), 1)
			billboard.Enabled = health > 0
		end
	end

	unit:GetAttributeChangedSignal("Health"):Connect(update)
	unit:GetAttributeChangedSignal("MaxHealth"):Connect(update)
	unit:GetAttributeChangedSignal("Dead"):Connect(update)
	update()
end

return Utility
]]></ProtectedString>
