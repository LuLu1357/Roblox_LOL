{
  "name": "GameTest",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Modules": {
        "$path": "src/shared/modules"
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      }
    },

    "StarterPlayer": {
      "$properties": {
        "DevComputerMovementMode": "Scriptable"
      },
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        }
      }
    },

    "Workspace": {
      "$ignoreUnknownInstances": true,
      "$properties": {
        "FilteringEnabled": true,
        "FallenPartsDestroyHeight": -100
      }
    },
    "Lighting": {
      "$ignoreUnknownInstances": true,
      "$properties": {
        "Ambient": [0.24, 0.27, 0.30],
        "Brightness": 2.4,
        "ClockTime": 15.2,
        "GlobalShadows": true,
        "Outlines": false
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}
